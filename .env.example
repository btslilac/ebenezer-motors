# ─── FRONTEND (Vite — only VITE_* vars are exposed to the browser) ────────────
VITE_API_BASE_URL=https://your-app.vercel.app

# ─── SERVER (set in Vercel dashboard, or in server/.env for local dev) ────────
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ebenezer-motors
JWT_SECRET=<long-random-secret>
JWT_EXPIRES_IN=7d
ADMIN_REGISTRATION_KEY=<your-registration-key>
CORS_ORIGIN=https://your-app.vercel.app

# ─── Storage — Cloudflare R2 (S3-compatible) ──────────────────────────────────
STORAGE_DRIVER=s3
S3_REGION=auto
S3_BUCKET=<your-bucket-name>
S3_ACCESS_KEY_ID=<r2-access-key-id>
S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_BASE_URL=https://<your-r2-public-domain>.r2.dev
S3_FORCE_PATH_STYLE=true
